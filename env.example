# Шаблон: скопировать в .env на сервере.
#
# Порядок первого деплоя:
# 1) В .env поставьте USE_TLS=False, пока certbot не выписал сертификат (обычно 1 команда после nginx).
# 2) certbot --nginx ...
# 3) В .env USE_TLS=True и restart gunicorn/modelix.

DEBUG=False
USE_TLS=True

SECRET_KEY=замените-на-случайную-строку

ALLOWED_HOSTS=3dmodelix.ru,www.3dmodelix.ru,89.108.78.232,localhost,127.0.0.1
